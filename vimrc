" General Settings
syntax enable
set background=dark
colorscheme solarized
set number
set relativenumber
set showmatch
set ignorecase
set smartcase
set incsearch
set hlsearch
set autoindent
set smartindent
set laststatus=2
set cursorline
set wildmenu

" Tab Settings
set tabstop=2
set shiftwidth=2
set expandtab

" Search Clear
nnoremap <esc><esc> :noh<return><esc>
